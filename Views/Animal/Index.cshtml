@model List<PetAdoptionMVC.Models.Animal>


@{
    ViewData["Title"] = "Animals";
}

<h2>Animals</h2>


<p>
    <a asp-action="Create" class="btn btn-primary">Add New Animal</a>
</p>

<table class="table table-striped">
    <thead>
        <tr>
            <th>Name</th>
            <th>Type</th>
            <th>Age</th>
            <th>Color</th>
            <th>Vaccinated</th>
            <th>Adopted</th>
            <th>Actions</th>
        </tr>
    </thead>
    <tbody>
        @foreach(var animal in Model)
        {
            <tr>
                <td>@animal.Name</td>
                <td>@animal.AnimalType</td>
                <td>@animal.Age</td>
                <td>@animal.Color</td>

                <td>@(animal.IsVaccinated ? "Yes" : "No")</td>
                <td>@(animal.IsAdopted ? "Adopted" : "Available")</td>
                <td>
                   <a asp-action="Details" asp-route-id="@animal.Id"
                        class="btn btn-sm btn-info">Details</a>
                    <a asp-action="Edit" asp-route-id="@animal.Id" 
                        class="btn btn-sm btn-warning" >Edit</a>
                    <a asp-action="Deactivate" asp-route-id="@animal.Id"
                        class="btn btn-sm btn-danger">Remove</a>
                </td>
            </tr>
        }
    </tbody>
</table>