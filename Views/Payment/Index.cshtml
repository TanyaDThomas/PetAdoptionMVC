@model IEnumerable<PetAdoptionMVC.ViewModels.PaymentListViewModel>


@{
    ViewData["Title"] = "List of Payments";
}

<h2>Payments</h2>

<p> <a asp-action="Create" class="btn btn-primary">Create New Payment</a></p>

<form method="get">
    <div class="row">
        <div class="col-md-3">
            <label>Status</label>
            <select name="Status" class="form-control">
                <option value="">All</option>
                <option value="Completed">Completed</option>
                <option value="Pending">Pending</option>
                <option value="Failed">Failed</option>
            </select>
        </div>

        <div class="col-md-3">
            <label>Payment Type</label>
            <select name="PaymentType" class="form-control">
                <option value="">All</option>
                <option value="Cash">Cash</option>
                <option value="Card">Card</option>
                <option value="PayPal">PayPal</option>
            </select>
        </div>

        <div class="col-md-3">
            <label>From Date</label>
            <input type="date" name="PaymentDateFrom" class="form-control" />
        </div>

        <div class="col-md-3">
            <label>To Date</label>
            <input type="date" name="PaymentDateTo" class="form-control" />
        </div>
    </div>

    <br />

    <button type="submit" class="btn btn-primary">Search</button>
</form>

<br />

<table class="table table-striped">
    <thead>
        <tr>
            <th>Amount</th>
            <th>Type</th>
            <th>Status</th>
            <th>Date</th>
            <th>Adopter</th>
            <th>Receipt</th>
            <th></th>
        </tr>
    </thead>
    <tbody>
        @foreach (var payment in Model)
        {
            <tr>
                <td>@payment.Amount.ToString("C")</td>
                <td>@payment.Type</td>
                <td>
                    @if (payment.Status == "Completed")
                    {
                        <span class="text-success">@payment.Status</span>
                    }
                    else if (payment.Status == "Failed")
                    {
                        <span class="text-danger">@payment.Status</span>
                    }
                    else
                    {
                        <span>@payment.Status</span>
                    }
                </td>
                <td>@payment.PaymentDate.ToShortDateString()</td>
                <td>@payment.AdopterId</td>
                <td>@payment.ReceiptNumber</td>
            
                <td>
                    <a asp-action="Details" asp-controller="Payment"
                       asp-route-id="@payment.Id"
                       class="btn btn-sm btn-info">Details</a>
                    <a asp-action="Edit" asp-controller="Payment"
                       asp-route-id="@payment.Id"
                       class="btn btn-sm btn-warning">Edit</a>
                    <form asp-action="Deactivate" asp-controller="Payment" asp-route-id="@payment.Id" method="post" class="d-inline">
                        <button type="submit" class="btn btn-sm btn-danger">Remove</button>
                    </form>

                </td>
                
            </tr>
        }
    </tbody>
    <tfoot></tfoot>
</table>
