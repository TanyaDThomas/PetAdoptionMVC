@model PetAdoptionMVC.Models.Dog

@{
    ViewData["Title"] = "Edit Dog";
}

<h2>Edit @Model.Name</h2>

<form asp-action="Edit">
    @Html.AntiForgeryToken()
    <input type="hidden" asp-for="Id" />
    <div asp-validation-summary="ModelOnly" class="text-danger"></div>

    <h4>Basic Information</h4>
    <hr />
    <div class="row mb-3">
        <div class="col-md-6">
            <label asp-for="Name" class="form-label"></label>
            <input asp-for="Name" class="form-control" />
            <span asp-validation-for="Name" class="text-danger"></span>
        </div>
        <div class="col-md-6">
            <label asp-for="Breed" class="form-label"></label>
            <input asp-for="Breed" class="form-control" />
            <span asp-validation-for="Breed" class="text-danger"></span>
        </div>
    </div>
    <div class="row mb-3">
        <div class="col-md-4">
            <label asp-for="Age" class="form-label"></label>
            <input asp-for="Age" class="form-control" />
        </div>
        <div class="col-md-4">
            <label asp-for="Color" class="form-label"></label>
            <input asp-for="Color" class="form-control" />
        </div>
        <div class="col-md-4">
            <label asp-for="AdoptionFee" class="form-label"></label>
            <input asp-for="AdoptionFee" class="form-control" />
        </div>
    </div>

    <h4>Behavior & Temperament</h4>
    <hr />
    <div class="row mb-3">
        <div class="col-md-3">
            <div class="form-check">
                <input asp-for="IsHouseTrained" class="form-check-input" />
                <label asp-for="IsHouseTrained" class="form-check-label"></label>
            </div>
        </div>
        <div class="col-md-3">
            <div class="form-check">
                <input asp-for="IsGoodWithChildren" class="form-check-input" />
                <label asp-for="IsGoodWithChildren" class="form-check-label"></label>
            </div>
        </div>
        <div class="col-md-3">
            <div class="form-check">
                <input asp-for="IsGoodWithOtherPets" class="form-check-input" />
                <label asp-for="IsGoodWithOtherPets" class="form-check-label"></label>
            </div>
        </div>
        <div class="col-md-3">
            <div class="form-check">
                <input asp-for="IsFriendly" class="form-check-input" />
                <label asp-for="IsFriendly" class="form-check-label"></label>
            </div>
        </div>
    </div>

    <h4>Health</h4>
    <hr />
    <div class="row mb-3">
        <div class="col-md-3">
            <div class="form-check">
                <input asp-for="IsVaccinated" class="form-check-input" />
                <label asp-for="IsVaccinated" class="form-check-label"></label>
            </div>
        </div>
        <div class="col-md-3">
            <div class="form-check">
                <input asp-for="HasSpecialCareNeeds" class="form-check-input" />
                <label asp-for="HasSpecialCareNeeds" class="form-check-label"></label>
            </div>
        </div>
        <div class="col-md-3">
            <div class="form-check">
                <input asp-for="HasSpecialDiet" class="form-check-input" />
                <label asp-for="HasSpecialDiet" class="form-check-label"></label>
            </div>
        </div>
    </div>

    <div class="mt-3">
        <button type="submit" class="btn btn-primary">Save Changes</button>
        @* <a asp-action="Index" class="btn btn-secondary">Cancel</a> *@
        <a href="@ViewBag.ReturnUrl" class="btn btn-secondary">Cancel</a>
    </div>

</form>

@section Scripts {
    @{await Html.RenderPartialAsync("_ValidationScriptsPartial");}
}