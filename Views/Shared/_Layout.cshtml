                    @* <div class="fh-submenu">
                        <a class="fh-nav-subitem @(ViewData["ActivePage"]?.ToString() == "OtherFish" ? "active" : "")"
                           asp-controller="Fish" asp-action="Index">Fish</a>
                        <a class="fh-nav-subitem @(ViewData["ActivePage"]?.ToString() == "OtherBirds" ? "active" : "")"
                           asp-controller="Bird" asp-action="Index">Birds</a>
                        <a class="fh-nav-subitem @(ViewData["ActivePage"]?.ToString() == "OtherReptiles" ? "active" : "")"
                           asp-controller="Reptile" asp-action="Index">Reptiles</a>
                        <a class="fh-nav-subitem @(ViewData["ActivePage"]?.ToString() == "OtherSmall" ? "active" : "")"
                           asp-controller="SmallAnimal" asp-action="Index">Small Animals</a>
                        <a class="fh-nav-subitem @(ViewData["ActivePage"]?.ToString() == "OtherFarm" ? "active" : "")"
                           asp-controller="FarmAnimal" asp-action="Index">FarmAnimals</a>
                        <a class="fh-nav-subitem @(ViewData["ActivePage"]?.ToString() == "OtherExotic" ? "active" : "")"
                           asp-controller="ExoticAnimal" asp-action="Index">ExoticAnimals</a>

                    </div> *@
                </div>

            </div>

            <div class="fh-sidebar-divider"></div>

            <div class="fh-sidebar-section">
                <span class="fh-sidebar-label">Management</span>

                <a class="fh-nav-item @(ViewData["ActivePage"]?.ToString() == "Reports" ? "active" : "")"
                   asp-controller="Report" asp-action="Index">
                    <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                        <path d="M14 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V8z" />
                        <polyline points="14 2 14 8 20 8" />
                        <line x1="16" y1="13" x2="8" y2="13" />
                        <line x1="16" y1="17" x2="8" y2="17" />
                        <polyline points="10 9 9 9 8 9" />
                    </svg>
                    Reports
                </a>

                <a class="fh-nav-item @(ViewData["ActivePage"]?.ToString() == "Admin" ? "active" : "")"
                   asp-controller="Admin" asp-action="Index">
                    <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                        <circle cx="12" cy="12" r="3" />
                        <path d="M19.07 4.93a10 10 0 0 1 0 14.14M4.93 4.93a10 10 0 0 0 0 14.14" />
                    </svg>
