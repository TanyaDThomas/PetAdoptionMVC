<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - Forever Home</title>

    <!-- Google Fonts -->
    <link href="https://fonts.googleapis.com/css2?family=Playfair+Display:wght@600&family=Nunito:wght@400;500;600&display=swap" rel="stylesheet" />

    <!-- Bootstrap -->
    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css" />

    <!-- Forever Home Styles -->
    <link rel="stylesheet" href="~/css/forever-home.css" asp-append-version="true" />

    @await RenderSectionAsync("Styles", required: false)
</head>
<body>

    <!-- =====================
         TOP NAVBAR
    ===================== -->
    <nav class="fh-navbar">

        <!-- Logo + Brand Name -->
        <a class="fh-brand" asp-area="" asp-controller="Home" asp-action="Index">
            <svg width="36" height="36" viewBox="0 0 36 36" fill="none" xmlns="http://www.w3.org/2000/svg">
                <!-- Paw pad (main) -->
                <ellipse cx="18" cy="22" rx="7" ry="6" fill="#C0392B" />
                <!-- Toe beans -->
                <ellipse cx="11" cy="15" rx="3.2" ry="2.6" fill="#C0392B" />
                <ellipse cx="18" cy="13" rx="3.2" ry="2.6" fill="#C0392B" />
                <ellipse cx="25" cy="15" rx="3.2" ry="2.6" fill="#C0392B" />
                <!-- Heart cutout on main pad -->
                <path d="M18 26 C18 26 14 23 14 21 C14 19.5 15.5 18.5 17 19.2 C17.5 19.5 18 20 18 20 C18 20 18.5 19.5 19 19.2 C20.5 18.5 22 19.5 22 21 C22 23 18 26 18 26Z" fill="#F5ECD7" />
            </svg>
            <div class="fh-brand-text">
                <span class="fh-brand-name">Forever Home</span>
                <span class="fh-brand-tagline">Rescue Network</span>
            </div>
        </a>

        <div class="fh-navbar-right">

            <!-- Notification Bell -->
            <a href="#" class="fh-icon-btn" title="Notifications">
                <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="rgba(245,236,215,0.75)" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                    <path d="M18 8A6 6 0 0 0 6 8c0 7-3 9-3 9h18s-3-2-3-9" />
                    <path d="M13.73 21a2 2 0 0 1-3.46 0" />
                </svg>
            </a>

            <!-- Sign In — swap with Identity partial once implemented -->
            <a class="fh-signin-btn" asp-area="" asp-controller="Account" asp-action="Login">
                <span>Sign In</span>
            </a>

            <!-- Hamburger (mobile only — shown via CSS) -->
            <button class="fh-hamburger" id="fh-hamburger-btn" aria-label="Toggle navigation" aria-expanded="false">
                <span></span>
                <span></span>
                <span></span>
            </button>

        </div>
    </nav>

    <!-- Sidebar overlay (mobile tap-to-close) -->
    <div class="fh-sidebar-overlay" id="fh-sidebar-overlay"></div>

    <!-- =====================
