@model PetAdoptionMVC.ViewModels.BirdDetailsViewModel

@{
    ViewData["Title"] = "Bird Details";
}

<h2>@Model.Bird.Name Details</h2>
<hr />


<div class="row">
    <div class="col-sm-6">
        <h4>Basic Information</h4>
        <hr />

        <dl>
            <dt class="col-sm-4">Name</dt>
            <dd class="col-sm-8">@Model.Bird.Name</dd>

            <dt class="col-sm-4">Species</dt>
            <dd class="col-sm-8">@Model.Bird.Species</dd>

            <dt class="col-sm-4">Color</dt>
            <dd class="col-sm-8">@Model.Bird.Color</dd>

            <dt class="col-sm-4">Age</dt>
            <dd class="col-sm-8">@Model.Bird.Age</dd>

            <dt class="col-sm-4">Date of Birth</dt>
            <dd class="col-sm-8">@Model.Bird.DOB.ToShortDateString()</dd>

            <dt class="col-sm-4">Adoption Fee</dt>
            <dd class="col-sm-8">@Model.Bird.AdoptionFee.ToString("C")</dd>

            <dt class="col-sm-4">Status</dt>
            <dd class="col-sm-8">@(Model.Bird.IsAdopted ? "Adopted" : "Available")</dd>
        </dl>
    </div>

    <div class="col-md-6">
        <h4>Behavior and Health</h4>
        <hr />

        <dl class="row">
            <dt class="col-sm-5">Is Good With Other Birds</dt>
            <dd class="col-sm-7">@(Model.Bird.IsGoodWithOtherBirds ? "Yes" : "No")</dd>

            <dt class="col-sm-5">Is Good With Kids</dt>
            <dd class="col-sm-7">@(Model.Bird.IsGoodWithChildren ? "Yes" : "No")</dd>

            <dt class="col-sm-5">Is Good With Pets</dt>
            <dd class="col-sm-7">@(Model.Bird.IsGoodWithOtherPets ? "Yes" : "No")</dd>

            <dt class="col-sm-5">Is Hand Tamed</dt>
            <dd class="col-sm-7">@(Model.Bird.IsHandTamed ? "Yes" : "No")</dd>

            <dt class="col-sm-5">Can Fly</dt>
            <dd class="col-sm-7">@(Model.Bird.CanFly ? "Yes" : "No")</dd>

            <dt class="col-sm-5">Is Hand Tamed</dt>
            <dd class="col-sm-7">@(Model.Bird.NeedsLargeCage ? "Yes" : "No")</dd>
        </dl>
    </div>
</div>

<div class="col-md-6">
    <h4>Health</h4>
    <hr />

    <dl class="row">

        <dt class="col-sm-5">Vaccinated</dt>
        <dd class="col-sm-7">@(Model.Bird.IsVaccinated ? "Yes" : "No")</dd>

        <dt class="col-sm-5">Special Care Needs</dt>
        <dd class="col-sm-7">@(Model.Bird.HasSpecialCareNeeds ? "Yes" : "No")</dd>

        <dt class="col-sm-5">Special Diet</dt>
        <dd class="col-sm-7">@(Model.Bird.HasSpecialDiet ? "Yes" : "No")</dd>

    </dl>
</div>

<div class="mt-4">
    <div class="d-flex justify-content-between align-items-center">
        <h4>Recent Notes</h4>
        <div>
            <a asp-action="Create" asp-controller="Note"
               asp-route-entityType="@Model.EntityType"
               asp-route-entityId="@Model.Bird.Id"
               asp-route-returnUrl="@Url.Action("Details", "Bird", new { id = Model.Bird.Id })"
               class="btn btn-primary">Add Note</a>

            <a asp-action="Index" asp-controller="Note"
               asp-route-entityType="@Model.EntityType"
               asp-route-entityId="@Model.Bird.Id"
               class="btn btn-sm btn-secondary ms-2">View All Notes</a>
        </div>
    </div>
    <hr />

    @if (Model.RecentNotes.Any())
    {
        @foreach (var note in Model.RecentNotes)
        {
            <div class="card mb-2">
                <div class="card-body">
                    <strong>@note.Category</strong>
                    <span class="text-muted float-end">@note.CreatedOn.ToShortDateString()</span>
                    <p class="mb-0 mt-1">@note.Content</p>
                </div>
            </div>
        }
    }
    else
    {
        <p class="text-muted">No notes for this animal yet.</p>
    }
</div>



<hr />


<div class="mt-3">
    <a asp-action="Edit" asp-route-id="@Model.Bird.Id" class="btn btn-warning">Edit</a>

    <a href="@Model.ReturnUrl" class="btn btn-secondary">Back to List</a>
</div>

