@model IEnumerable<PetAdoptionMVC.Models.FarmAnimal>

@{
    ViewData["Title"] = "List of Farm Animals";
}

<h2>List of Farm Animals</h2>
<hr />

<p><a asp-action="Create" class="btn btn-primary">Add Farm Animal</a></p>

<table class="table table-striped">
    <thead>
       <tr>
            <th>Name</th>
            <th>Species</th>
            <th>Age</th>
            <th>Color</th>
            <th>Needs Outdoor Space</th>
            <th>Good With Kids</th>
            <th>Good With Pets</th>
            <th>Vaccinated</th>
            <th>Status</th>
            <th>Actions</th>
       </tr>
    </thead>
    <tbody>
        @foreach (var farmAnimal in Model)
        {
            <tr>
                <td>@farmAnimal.Name</td>
                <td>@farmAnimal.Species</td>
                <td>@farmAnimal.Age</td>
                <td>@farmAnimal.Color</td>
                <td>@(farmAnimal.NeedsOutdoorSpace ? "Yes" : "No")</td>
                <td>@(farmAnimal.IsGoodWithChildren ? "Yes" : "No")</td>
                <td>@(farmAnimal.IsGoodWithOtherAnimals ? "Yes" : "No")</td>
                <td>@(farmAnimal.IsVaccinated ? "Yes" : "No")</td>
                <td>@(farmAnimal.IsAdopted ? "Adopted" : "Available")</td>
                <td>
                    <a asp-action="Details" asp-controller="FarmAnimal"
                    asp-route-id="@farmAnimal.Id"
                    asp-route-returnUrl="/FarmAnimal"
                    class="btn btn-sm btn-info">Details</a>

                    <a asp-action="Edit" asp-controller="FarmAnimal"
                    asp-route-id="@farmAnimal.Id"
                    asp-route-returnUrl="/FarmAnimal"
                    class="btn btn-sm btn-warning">Edit</a>

                    <form asp-action="Deactivate" asp-controller="FarmAnimal"
                          asp-route-id="@farmAnimal.Id"
                          method="post"
                          class="d-inline">
                        <button type="submit" class="btn btn-sm btn-danger">Remove</button>
                    </form>
                </td>
            </tr>
        }
    </tbody>
    <tfooter></tfooter>
</table>




