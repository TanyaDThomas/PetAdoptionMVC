@model PetAdoptionMVC.Models.FarmAnimal

@{
    ViewData["Title"] = "Edit Farm Animal";
}

<h2>Edit @Model.Name</h2>
<hr />

<form asp-action="Edit">
    <input type="hidden" asp-for="Id" />
    @Html.AntiForgeryToken()
    <div asp-validation-summary="ModelOnly" class="text-danger"></div>

    <h4>Basic Information</h4>
    <hr />

    <div class="row mb-3">
        <div class="col-md-6">
            <label asp-for="Name" class="form-label"></label>
            <input asp-for="Name" class="form-control" />
            <span asp-validation-for="Name" class="text-danger"></span>
        </div>
        <div class="col=md-6">
            <label asp-for="Species" class="form-label"></label>
            <input asp-for="Species" class="form-control" />
            <span asp-validation-for="Species" class="text-danger"></span>
        </div>
        <div class="col-md-6">
            <label asp-for="Color" class="form-label"></label>
            <input asp-for="Color" class="form-control" />
            <span asp-validation-for="Color" class="text-danger"></span>
        </div>
        <div class="col-md-6">
            <label asp-for="Age" class="form-label"></label>
            <input asp-for="Age" class="form-control" />
            <span asp-validation-for="Age" class="text-danger"></span>
        </div>
        <div class="col-md-6">
            <label asp-for="DOB" class="form-label"></label>
            <input asp-for="DOB" class="form-control" type="date" />
            <span asp-validation-for="DOB" class="text-danger"></span>
        </div>
        <div class="col-md-6">
            <label asp-for="AdoptionFee" class="form-label"></label>
            <input asp-for="AdoptionFee" class="form-control" />
            <span asp-validation-for="AdoptionFee" class="text-danger"></span>
        </div>
    </div>

    <h4>Behavior & Needs</h4>
    <hr />

    <div class="row mb-3">
        <div class="col-md-3">
            <div class="form-check">
                <input asp-for="IsHouseTrained" class="form-check-input" />
                <label asp-for="IsHouseTrained" class="form-check-label"></label>
            </div>
        </div>
        <div class="col-md-3">
            <div class="form-check">
                <input asp-for="IsGoodWithChildren" class="form-check-input" />
                <label asp-for="IsGoodWithChildren" class="form-check-label"></label>
            </div>
        </div>
        <div class="col-md-3">
            <div class="form-check">
                <input asp-for="IsGoodWithOtherAnimals" class="form-check-input" />
                <label asp-for="IsGoodWithOtherAnimals" class="form-check-label"></label>
            </div>
        </div>
        <div class="col-md-3">
            <div class="form-check">
                <input asp-for="NeedsCompanion" class="form-check-input" />
                <label asp-for="NeedsCompanion" class="form-check-label"></label>
            </div>
        </div>
        <div class="col-md-3">
            <div class="form-check">
                <input asp-for="NeedsOutdoorSpace" class="form-check-input" />
                <label asp-for="NeedsOutdoorSpace" class="form-check-label"></label>
            </div>
        </div>


    </div>

    <h4>Health</h4>
    <hr />

    <div class="row mb-3">
        <div class="col-md-3">
            <div class="form-check">
                <input asp-for="IsVaccinated" class="form-check-input" />
                <label asp-for="IsVaccinated" class="form-check-label"></label>
            </div>
        </div>
        <div class="col-md-3">
            <div class="form-check">
                <input asp-for="HasSpecialCareNeeds" class="form-check-input" />
                <label asp-for="HasSpecialCareNeeds" class="form-check-label"></label>
            </div>
        </div>
        <div class="col-md-3">
            <div class="form-check">
                <input asp-for="HasSpecialDiet" class="form-check-input" />
                <label asp-for="HasSpecialDiet" class="form-check-label"></label>
            </div>
        </div>

    </div>

    <div class="mt-3">
        <button type="submit" class="btn btn-sm btn-warning">Save Changes</button>
        <a href="@ViewBag.ReturnUrl" class="btn btn-secondary">Cancel</a>
    </div>
</form>

@section Scripts {
@{
        await Html.RenderPartialAsync("_ValidationScriptsPartial");
    }
}