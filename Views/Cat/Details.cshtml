@model PetAdoptionMVC.ViewModels.CatDetailsViewModel

@{
    ViewData["Title"] = "Cat Details";
}

<h2>@Model.Cat.Name</h2>

<div class="row">
    <div class="col-md-6">
        <h4>Basic Information</h4>
        <hr />

        <dl class="row">
            <dt class="col-sm-4">Name</dt>
            <dd class="col-sm-8">@Model.Cat.Name</dd>

            <dt class="col-sm-4">Breed</dt>
            <dd class="col-sm-8">@Model.Cat.Breed</dd>

            <dt class="col-sm-4">Age</dt>
            <dd class="col-sm-8">@Model.Cat.Age</dd>

            <dt class="col-sm-4">Color </dt>
            <dd class="col-sm-8">@Model.Cat.Color</dd>

            <dt class="col-sm-4">Date of Birth</dt>
            <dd class="col-sm-8">@Model.Cat.DOB.ToShortDateString()</dd>

            <dt class="col-sm-4">Adoption Fee</dt>
            <dd class="col-sm-8">@Model.Cat.AdoptionFee.ToString("C")</dd>

            <dt class="col-sm-4">Status</dt>
            <dd class="col-sm-8">@(Model.Cat.IsAdopted ? "Adopted" : "Available")</dd>
        </dl>

    </div>

    <div class="col-md-6">
        <h4>Behavior and Health</h4>
        <hr />
        
        <dl class="row">
            <dt class="col-sm-5">Litter Trained</dt>
            <dd class="col-sm-7">@(Model.Cat.IsLitterTrained ? "Yes" : "No")</dd>

            <dt class="col-sm-5">Good With Kids</dt>
            <dd class="col-sm-7">@(Model.Cat.IsGoodWithChildren ? "Yes" : "No")</dd>

            <dt class="col-sm-5">Good With Pets</dt>
            <dd class="col-sm-7">@(Model.Cat.IsGoodWithOtherPets ? "Yes" : "No")</dd>

            <dt class="col-sm-5">Indoor Only</dt>
            <dd class="col-sm-7">@(Model.Cat.IsIndoorOnly ? "Yes" : "No")</dd>

            <dt class="col-sm-5">Friendly</dt>
            <dd class="col-sm-7">@(Model.Cat.IsFriendly ? "Yes" : "No")</dd>

            <dt class="col-sm-5">Vaccinated</dt>
            <dd class="col-sm-7">@(Model.Cat.IsVaccinated ? "Yes" : "No")</dd>

            <dt class="col-sm-5">Special Care Needs</dt>
            <dd class="col-sm-7">@(Model.Cat.HasSpecialCareNeeds ? "Yes" : "No")</dd>

            <dt class="col-sm-5">Special Diet</dt>
            <dd class="col-sm-7">@(Model.Cat.HasSpecialDiet ? "Yes" : "No")</dd>

        </dl>
    </div>
</div>


<div class="mt-4">
    <div class="d-flex justify-content-between align-items-center">
        <h4>Recent Notes</h4>
        <div>
            <a asp-action="Create" asp-controller="Note"
               asp-route-entityType="@Model.EntityType"
               asp-route-entityId="@Model.Cat.Id"
               class="btn btn-sm btn-primary">Add Note</a>
            <a asp-action="Index" asp-controller="Note"
               asp-route-entityType="@Model.EntityType"
               asp-route-entityId="@Model.Cat.Id"
               class="btn btn-sm btn-secondary ms-2">View All Notes</a>
        </div>
    </div>
    <hr />

    @if (Model.RecentNotes.Any())
    {
        @foreach (var note in Model.RecentNotes)
        {
            <div class="card mb-2">
                <div class="card-body">
                    <strong>@note.Category</strong>
                    <span class="text-muted float-end">@note.CreatedOn.ToShortDateString()</span>
                    <p class="mb-0 mt-1">@note.Content</p>
                </div>
            </div>
        }
    }
    else
    {
        <p class="text-muted">No notes for this animal yet.</p>
    }
</div>


<hr />


<div class="mt-3">
    <a asp-action="Edit" asp-route-id="@Model.Cat.Id" class="btn btn-warning">Edit</a>

    <a href="@Model.ReturnUrl" class="btn btn-secondary">Back to List</a>
</div>

