@model PetAdoptionMVC.Models.Cat

@{
    ViewData["Title"] = "Create a New Cat";
}

<h2>Create a New Cat</h2>

<form asp-action="Create">
<div asp-validation-summary="ModelOnly" class="text-danger"></div>
    <h4>Basic Information</h4>
    <hr />

    <div class="row mb-3">
        <div class="col-md-6">
            <label asp-for="Name" class="form-label"></label>
            <input asp-for="Name" class="form-control" />
            <span asp-validation-for="Name" class="text-danger"></span>
        </div>

        <div class="col-md-6">
            <label asp-for="Breed" class="form-label"></label>
            <input asp-for="Breed" class="form-control" />
            <span asp-validation-for="Breed" class="text-danger"></span>
        </div>

        <div class="col-md-6">
            <label asp-for="Color" class="form-label"></label>
            <input asp-for="Color" class="form-control" />
            <span asp-validation-for="Color" class="text-danger"></span>
        </div>

        <div class="col-md-6">
            <label asp-for="Age" class="form-label"></label>
            <input asp-for="Age" class="form-control" />
            <span asp-validation-for="Age" class="text-danger"></span>
        </div>

        <div class="col-md-6">
            <label asp-for="DOB" class="form-label"></label>
            <input asp-for="DOB" class="form-control" type="date"/>
            <span asp-validation-for="DOB" class="text-danger"></span>
        </div>

        <div class="col-md-6">
            <label asp-for="AdoptionFee" class="form-label"></label>
            <input asp-for="AdoptionFee" class="form-control" />
            <span asp-validation-for="AdoptionFee" class="text-danger"></span>
        </div>
    </div>

    <h4>Behavior and Temperament</h4>
    <hr>

    <div class="row mb-3">
        <div class="col-md-3">
            <div class="form-check">
                <input asp-for="IsLitterTrained" class="form-check" />
                <label asp-for="IsLitterTrained" class="form-check-label"></label>
            </div>
        </div>

        <div class="col-md-3">
            <div class="form-check">
                <input asp-for="IsGoodWithChildren" class="form-check-input" />
                <label asp-for="IsGoodWithChildren" class="form-check-label"></label>
            </div>
        </div>

        <div class="col-md-3">
            <div class="form-check">
                <input asp-for="IsGoodWithOtherPets" class="form-check-input" />
                <label asp-for="IsGoodWithOtherPets" class="form--check"></label>
            </div>
        </div>

        <div class="col-md-3">
            <div class="form-check">
                <input asp-for="IsIndoorOnly" class="form-check-input" />
                <label asp-for="IsIndoorOnly" class="form-check-label"></label>
            </div>
        </div>

        <div class="col-md-3">
            <div class="form-check">
                <input asp-for="IsFriendly" class="form-check-input" />
                <label asp-for="IsFriendly" class="form-check-label"></label>
            </div>
        </div>

    </div>

    <h4>Health</h4>
    <hr />

    <div class="row mb-3">
        <div class="col-md-3">
            <div class="form-check">
                <input asp-for="IsVaccinated" class="form-check-input" />
                <label asp-for="IsVaccinated" class="form-check-label"></label>
            </div>
        </div>

        <div class="col-md-3">
            <div class="form-check">
                <input asp-for="HasSpecialCareNeeds" class="form-check-input" />
                <label asp-for="HasSpecialCareNeeds" class="form-check-label"></label>
            </div>
        </div>

        <div class="col-md-3">
            <div class="form-check">
                <input asp-for="HasSpecialDiet" class="form-check-input" />
                <label asp-for="HasSpecialDiet" class="form-check-label"></label>
            </div>
        </div>
    </div>

    <div class="mt-3">
        <button type="submit" class="btn btn-primary">Save</button>
        <a asp-action="Index" class="btn btn-secondary">Cancel</a>
    </div>


</form>

@section Scripts {
    @{
        await Html.RenderPartialAsync("_ValidationScriptsPartial");
    }
}